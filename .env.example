# ⚡ ULTRA INSTINCT — Variables d'environnement
# Copie ce fichier en .env et remplace les valeurs

# Supabase (obligatoire - va dans Project Settings > API)
SUPABASE_URL=https://ton-projet.supabase.co
SUPABASE_SERVICE_KEY=ta_secret_key_ici

# JWT Secret (change-le en production)
JWT_SECRET=ultra-instinct-secret-key-2026

# Port
PORT=3580

# Google Sheets (pour les commandes closer)
# Ces valeurs peuvent aussi être configurées par client dans le dashboard
# Ce sont les valeurs de fallback si le client n'a pas sa propre config
# GOOGLE_SHEET_ID=ton_spreadsheet_id
# GOOGLE_SERVICE_KEY={"type":"service_account",...}  # JSON du service account
# GOOGLE_SHEET_NAME=Commandes
